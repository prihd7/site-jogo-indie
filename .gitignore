# ==========================================
# Regras para arquivos INDEX e Compilados
# ==========================================
# Ignora arquivos index gerados na raiz (se você usa TS -> JS)
/index.js
/index.d.ts
/index.js.map

# ==========================================
# Logs
# ==========================================
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Diagnostic reports
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage / Reports
lib-cov
coverage
*.lcov
.nyc_output

# Build & Dependency Directories
node_modules/
jspm_packages/
web_modules/
build/Release
dist/
out/
.next/
.nuxt/
.svelte-kit/
.docusaurus/

# Caches e Configurações de Ferramentas
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
*.tsbuildinfo
.node_repl_history

# Environment Variables (Segurança!)
.env
.env.*
!.env.example

# Yarn v3
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Vite
vite.config.js.timestamp-*
vite.config.ts.timestamp-*
